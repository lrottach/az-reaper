terraform {
  required_version = ">= 1.9.0, < 2.0.0"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 4.0"
    }
    time = {
      source  = "hashicorp/time"
      version = "~> 0.12"
    }
  }
}

provider "azurerm" {
  features {}

  subscription_id                 = var.AZURE_SUBSCRIPTION_ID
  resource_provider_registrations = "none"
  storage_use_azuread             = true
}
