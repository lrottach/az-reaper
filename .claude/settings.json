{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "cleanupPeriodDays": 14,
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read(**)",
      "Edit(src/**/*.tf)",
      "Edit(src/**/*.hcl)",
      "Edit(environments/**/*.hcl)",
      "Edit(common/**/*.hcl)",
      "Edit(**/*.ps1)",
      "Edit(**/*.sh)",
      "Edit(**/*.yaml)",
      "Edit(**/*.yml)",
      "Edit(**/*.md)",
      "Edit(.claude/**)",
      "Edit(.devcontainer/**)",
      "Edit(.gitignore)",
      "Edit(root.hcl)",
      "Bash(terraform:*)",
      "Bash(terragrunt:*)",
      "Bash(az:*)",
      "Bash(pwsh:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(tree:*)",
      "Bash(which:*)",
      "Bash(terraform-docs:*)",
      "Bash(tflint:*)",
      "Bash(tfsec:*)",
      "Bash(checkov:*)"
    ],
    "deny": [
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/*.tfvars)",
      "Edit(**/*.tfvars.json)",
      "Edit(**/*.tfstate)",
      "Edit(**/*.tfstate.*)",
      "Edit(**/.terraform/**)",
      "Edit(**/.terragrunt-cache/**)",
      "Edit(**/*_override.tf)",
      "Edit(**/override.tf)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(sudo:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  }
}
