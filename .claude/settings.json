{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "cleanupPeriodDays": 14,
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read(**)",
      "Edit(src/**/*.cs)",
      "Edit(src/**/*.csproj)",
      "Edit(src/**/*.sln)",
      "Edit(src/**/host.json)",
      "Edit(src/**/local.settings*.json)",
      "Edit(infra/**/*.bicep)",
      "Edit(**/*.ps1)",
      "Edit(**/*.sh)",
      "Edit(**/*.yaml)",
      "Edit(**/*.yml)",
      "Edit(**/*.md)",
      "Edit(**/*.http)",
      "Edit(.claude/**)",
      "Edit(.devcontainer/**)",
      "Edit(.vscode/**)",
      "Edit(.gitignore)",
      "Edit(docker-compose.yml)",
      "Bash(dotnet:*)",
      "Bash(func:*)",
      "Bash(az:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(podman:*)",
      "Bash(podman-compose:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(tree:*)",
      "Bash(which:*)",
      "Bash(gh:*)"
    ],
    "deny": [
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/local.settings.json)",
      "Edit(**/bin/**)",
      "Edit(**/obj/**)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(sudo:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  }
}
